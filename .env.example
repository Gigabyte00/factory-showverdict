# ============================================================================
# Factory Site Template - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values for local development.
# For Vercel deployment, add these in the project's Environment Variables.
# ============================================================================

# ----------------------------------------------------------------------------
# Required: Site Identity
# ----------------------------------------------------------------------------
# Unique identifier for this site (UUID from Supabase sites table)
SITE_ID=

# URL-friendly slug (e.g., "electric-bikes" or "budget-laptops")
SITE_SLUG=

# Display name for the site
SITE_NAME=

# ----------------------------------------------------------------------------
# Required: Supabase Connection
# ----------------------------------------------------------------------------
# Supabase project URL (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Optional: Site Configuration
# ----------------------------------------------------------------------------
# Custom domain (e.g., "mysite.com")
SITE_DOMAIN=

# Site niche/category (e.g., "Electric Bikes", "Personal Finance")
SITE_NICHE=

# Site type: affiliate | blog | landing | ecommerce
SITE_TYPE=affiliate

# ----------------------------------------------------------------------------
# Optional: Theme Configuration
# ----------------------------------------------------------------------------
# Either provide full JSON config:
# SITE_THEME_CONFIG={"primaryColor":"#3B82F6","accentColor":"#2563EB","fontFamily":"Inter","logoUrl":null}

# Or individual values:
SITE_PRIMARY_COLOR=#3B82F6
SITE_ACCENT_COLOR=#2563EB
SITE_FONT_FAMILY=Inter
SITE_LOGO_URL=

# ----------------------------------------------------------------------------
# Optional: Feature Flags
# ----------------------------------------------------------------------------
SITE_FEATURE_BLOG=true
SITE_FEATURE_OFFERS=true
SITE_FEATURE_NEWSLETTER=false

# ----------------------------------------------------------------------------
# Optional: Settings
# ----------------------------------------------------------------------------
# Custom footer text
SITE_FOOTER_TEXT=

# Plausible Analytics domain (if using Plausible)
SITE_PLAUSIBLE_DOMAIN=
